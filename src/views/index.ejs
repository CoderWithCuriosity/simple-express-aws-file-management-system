<!DOCTYPE html>
<html>
<head>
    <title>File Upload</title>

    <style>
        body{
            font-family: Arial;
            max-width: 700px;
            margin: auto;
            padding: 30px;
        }

        .card{
            border:1px solid #ddd;
            padding:20px;
            border-radius:10px;
        }

        button{
            padding:10px 20px;
            cursor:pointer;
        }
    </style>
</head>
<body>

<h1>File Manager</h1>

<div class="card">
    <form
        action="/api/upload"
        method="POST"
        enctype="multipart/form-data"
    >
        <input
            type="file"
            name="file"
            required
        >

        <button>
            Upload
        </button>
    </form>
</div>

<br>

<a href="/files">
    View Files
</a>

</body>
</html>